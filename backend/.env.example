# AuditFlow — Backend environment template
# Copiar a .env y ajustar los valores marcados con [CAMBIAR EN PRODUCCION].

# ── Base de datos ─────────────────────────────────────────────────────────────
# Desarrollo local: coincide con el servicio 'db' de docker-compose.yml.
# Producción [CAMBIAR EN PRODUCCION]: usar credenciales distintas y un host real.
DATABASE_URL=postgresql+psycopg://auditflow:auditflow@localhost:5432/auditflow

# ── Seguridad ─────────────────────────────────────────────────────────────────
# [CAMBIAR EN PRODUCCION] — generar con: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production

# ── NVD API key (opcional) ────────────────────────────────────────────────────
# Gratis en: https://nvd.nist.gov/developers/request-an-api-key
# Sin clave: 5 req/30s | Con clave: 50 req/30s
NVD_API_KEY=

# ── Escaneo ───────────────────────────────────────────────────────────────────
# Puertos a excluir del escaneo nmap (coma-separados).
# Desarrollo: 8000 (backend) y 5173 (Vite). Producción con Nginx: 80,443
EXCLUDED_PORTS=8000,5173

# ── Usuarios de bootstrap ─────────────────────────────────────────────────────
# Creados en el primer arranque si no existen.
# [CAMBIAR EN PRODUCCION]
ADMIN_PASSWORD=admin
OPERATOR_PASSWORD=operator

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos (coma-separados). Producción: solo el dominio real.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
