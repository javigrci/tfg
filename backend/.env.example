# AuditFlow — Backend environment template
# Copiar a .env y rellenar con los valores reales.

# Base de datos — PostgreSQL
DATABASE_URL=postgresql+psycopg://auditflow:auditflow@localhost:5432/auditflow

# JWT — generar clave segura con: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production

# NVD API key (opcional — gratis en https://nvd.nist.gov/developers/request-an-api-key)
# Sin clave: 5 req/30s | Con clave: 50 req/30s
NVD_API_KEY=

# Puertos a excluir del escaneo nmap (coma-separados)
# En producción con Nginx usar: EXCLUDED_PORTS=80,443
EXCLUDED_PORTS=8000,5173

# Usuarios de bootstrap — creados en el primer arranque si no existen
ADMIN_PASSWORD=admin
OPERATOR_PASSWORD=operator

# CORS — orígenes permitidos (coma-separados)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
